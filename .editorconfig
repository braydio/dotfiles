# .editorconfig for a creatively organized project
root = true

# Default settings for all files
[*]
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown documentation (.md files)
[*.md]
indent_size = 2                      # Small indentation for better readability in docs
max_line_length = 80                  # Enforce short line lengths
trim_trailing_whitespace = true       # Keep lines tidy
insert_final_newline = true

# JavaScript files (creative rules for readability)
[*.js]
indent_style = space
indent_size = 2
quote_type = single                   # Enforce single quotes for consistency
max_line_length = 88
insert_final_newline = true
trim_trailing_whitespace = true

# SQL files (visual separation for readability)
[*.sql]
indent_style = space
indent_size = 4
max_line_length = 120
insert_final_newline = true
trim_trailing_whitespace = true

# CSS and SCSS (enforcing neatness)
[*.css, *.scss]
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Python files, with stricter rules for complex files
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88                  # Keeps code concise per PEP8
insert_final_newline = true
trim_trailing_whitespace = true

# TODO files (with emoji reminders in comments)
[*.todo]
max_line_length = 80
insert_final_newline = true
trim_trailing_whitespace = true

# Log files, always clean and tidy
[*.log]
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

# JSON files for configurations
[*.json]
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
